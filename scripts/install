#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "${SOURCE}" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "${SOURCE}")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${SOURCE_DIR}/${SOURCE}"
done

SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." >/dev/null 2>&1 && pwd)"

SKILL_NAME="${MYBRAIN_SKILL_NAME:-knowledge-base}"
CODEX_HOME="${CODEX_HOME:-${HOME}/.codex}"
TARGET_SKILL_DIR="${MYBRAIN_SKILL_DIR:-${CODEX_HOME}/skills/${SKILL_NAME}}"
BIN_DIR="${MYBRAIN_BIN_DIR:-${HOME}/.local/bin}"
VENV_DIR="${MYBRAIN_VENV:-${REPO_ROOT}/.venv}"
PYTHON_BIN="${PYTHON:-python3}"
INSTALL_DEPS=1
INSTALL_SKILL=1
INSTALL_CLI=1

usage() {
  cat <<'USAGE'
Usage: scripts/install [options]

Install or refresh the local Codex skill and kb CLI wrapper from this checkout.

Options:
  --skill-dir PATH   Skill install path. Defaults to ${CODEX_HOME:-~/.codex}/skills/knowledge-base.
  --bin-dir PATH     CLI wrapper directory. Defaults to ~/.local/bin.
  --venv PATH        Python virtualenv path. Defaults to <repo>/.venv.
  --python PATH      Python executable used to create the virtualenv.
  --skip-deps        Do not create/update the virtualenv or install package dependencies.
  --skip-skill       Do not copy kb-skill into the Codex skills directory.
  --skip-cli         Do not write the local kb wrapper.
  -h, --help         Show this help.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skill-dir)
      [[ $# -lt 2 ]] && { echo "--skill-dir requires a path" >&2; exit 2; }
      TARGET_SKILL_DIR="$2"
      shift 2
      ;;
    --bin-dir)
      [[ $# -lt 2 ]] && { echo "--bin-dir requires a path" >&2; exit 2; }
      BIN_DIR="$2"
      shift 2
      ;;
    --venv)
      [[ $# -lt 2 ]] && { echo "--venv requires a path" >&2; exit 2; }
      VENV_DIR="$2"
      shift 2
      ;;
    --python)
      [[ $# -lt 2 ]] && { echo "--python requires a path" >&2; exit 2; }
      PYTHON_BIN="$2"
      shift 2
      ;;
    --skip-deps)
      INSTALL_DEPS=0
      shift
      ;;
    --skip-skill)
      INSTALL_SKILL=0
      shift
      ;;
    --skip-cli)
      INSTALL_CLI=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ ! -d "${REPO_ROOT}/kb-skill" ]]; then
  echo "kb-skill directory not found under ${REPO_ROOT}" >&2
  exit 1
fi

if [[ "${INSTALL_DEPS}" -eq 1 ]]; then
  if [[ ! -x "${VENV_DIR}/bin/python" ]]; then
    "${PYTHON_BIN}" -m venv "${VENV_DIR}"
  fi
  "${VENV_DIR}/bin/python" -m pip install -e "${REPO_ROOT}"
fi

WRAPPER_PYTHON="${PYTHON_BIN}"
if [[ -x "${VENV_DIR}/bin/python" ]]; then
  WRAPPER_PYTHON="${VENV_DIR}/bin/python"
fi

if [[ "${INSTALL_SKILL}" -eq 1 ]]; then
  mkdir -p "$(dirname "${TARGET_SKILL_DIR}")"
  rm -rf "${TARGET_SKILL_DIR}"
  cp -R "${REPO_ROOT}/kb-skill" "${TARGET_SKILL_DIR}"
fi

if [[ "${INSTALL_CLI}" -eq 1 ]]; then
  mkdir -p "${BIN_DIR}"
  WRAPPER_PATH="${BIN_DIR}/kb"
  REPO_ROOT_Q="$(printf "%q" "${REPO_ROOT}")"
  PYTHON_BIN_Q="$(printf "%q" "${WRAPPER_PYTHON}")"
  cat > "${WRAPPER_PATH}" <<EOF
#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=${REPO_ROOT_Q}
PYTHON_BIN=${PYTHON_BIN_Q}

export PYTHONPATH="\${REPO_ROOT}\${PYTHONPATH:+:\${PYTHONPATH}}"
exec "\${PYTHON_BIN}" -m kb_cli.cli "\$@"
EOF
  chmod +x "${WRAPPER_PATH}"
fi

echo "Installed MyBrain from ${REPO_ROOT}"
if [[ "${INSTALL_SKILL}" -eq 1 ]]; then
  echo "Skill: ${TARGET_SKILL_DIR}"
fi
if [[ "${INSTALL_CLI}" -eq 1 ]]; then
  echo "CLI: ${BIN_DIR}/kb"
fi
if [[ "${INSTALL_DEPS}" -eq 1 ]]; then
  echo "Python: ${WRAPPER_PYTHON}"
fi
